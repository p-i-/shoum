# Shoum configuration.
# Flat `key: value` pairs only. Restart the app to apply.
# Delete a line to fall back to its built-in default.
# Comments stay on their own lines so the in-app Settings editor can rewrite a
# single value without clobbering them.
#
# This is the tracked TEMPLATE. Your live config.yaml is created from it on first
# run (run.sh in dev; the app itself when installed) and is NOT git-tracked, so
# local edits never show up as repo changes.

# Which whisper model to load (whisper.cpp/models/ggml-<model>.bin).
model: medium.en

# Where the heavy model assets (the .bin and its ANE encoder) live.
# Empty = the shared default, ~/Library/Application Support/Shoum/models, which
# both the dev build and the installed app reuse so the ~2 GB is never
# duplicated. Set an absolute path to relocate them (e.g. an external drive).
model_dir:

# CoreML/Neural Engine build (true) vs Metal only (false).
use_ane: true

# whisper-server port (localhost only).
server_port: 8178

# Extra whisper-server flags, space-separated (e.g. -t 6).
server_args:

# Logging verbosity: error | info | debug.
log_level: info

# Max gap between taps to count as a double-tap (ms).
double_tap_window_ms: 350

# Presses longer than this aren't taps (ms).
tap_max_ms: 250

# Double-tap-and-hold at least this long: release stops recording (ms).
hold_release_ms: 400

# Hotkey keycode: 56 = left shift, 60 = right shift.
hotkey_keycode: 56

# Audio feedback (Tink/Pop/Glass).
sounds: true

# paste = switch to previous app and Cmd+V; copy = clipboard only.
paste_mode: paste

# In terminals (iTerm, Terminal, Ghostty, kitty, Alacritty, WezTerm, Warp,
# Hyper), deliver the result by typing it as keystrokes instead of a Cmd+V paste
# — so editors like Claude Code don't collapse it to a "[Pasted N lines]"
# placeholder (newlines are sent as Shift+Return so nothing submits early). Only
# applies to those terminal apps; everything else still uses Cmd+V. Off by default.
type_into_terminals: false

# After pasting, put your previous clipboard contents back. Set false to leave
# the dictated text on the clipboard instead (and skip the restore entirely).
restore_clipboard: true

# Process spoken symbol/markdown commands: "ascii slash" -> /, "new paragraph" ->
# blank line, "cap apple" -> Apple, "mode ascii ... mode normal", etc. The full
# lexicon and rules are in lexicon.md. Set false to insert the raw transcription.
voice_commands: true

# Keep recorded WAVs in /tmp/shoum/wavs for 24h so misfires can be inspected,
# then auto-pruned. Set false to delete each clip right after transcription.
keep_recordings: true

# Prune dead (non-speech) audio before sending to whisper: Silero VAD removes
# silence so only speech is transcribed — cleaner punctuation and far more speech
# fits in whisper's 30s window. Needs the Silero model; if it's missing the raw
# audio is sent unchanged. Set false to always send the full recording.
prune_dead_audio: true

# Recordings whose loudness never rises above this (dBFS) are treated as
# no-speech and skipped — whisper hallucinates "Thank you" on silence. Measured
# silence sits ~-80 dBFS, real speech ~-25. Raise toward 0 to gate more
# aggressively; lower to let quieter clips through.
min_speech_dbfs: -60

# Check GitHub on launch and once a day while running; show "Update available"
# in the menu if a newer build exists. This is the only network call Shoum makes
# (metadata only — one commit hash). Set false to disable it entirely.
check_for_updates: true
